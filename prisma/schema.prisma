generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model User {
  id              Int          @id @default(autoincrement())
  email           String       @unique
  password        String
  name            String
  phone           String?
  avatar          String?
  role            UserRole     @default(CUSTOMER)
  status          UserStatus   @default(PENDING_VERIFICATION)
  emailVerified   Boolean      @default(false)
  emailVerifiedAt DateTime?
  savedAddresses  Json         @default("[]")

  shopName        String?
  shopDescription String?
  shopLogo        String?
  shopBanner      String?

  businessLicense String?
  taxCode         String?
  bankName        String?
  bankAccount     String?
  bankAccountName String?

  sellerStatus     SellerStatus?
  sellerApprovedAt DateTime?
  sellerApprovedBy Int?

  sellerRating       Float @default(0)
  sellerTotalReviews Int   @default(0)
  sellerTotalSales   Int   @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  measurements   Measurement[]
  cartItems      CartItem[]
  reviews        Review[]
  comments       Comment[]
  rentalOrders   RentalOrder[]
  notifications  Notification[]
  passwordResets PasswordReset[]
  sessions       Session[]

  ordersAsBuyer  Order[] @relation("CustomerOrders")
  ordersAsSeller Order[] @relation("SellerOrders")

  customOrdersAsBuyer  CustomOrder[] @relation("CustomerCustomOrders")
  customOrdersAsSeller CustomOrder[] @relation("SellerCustomOrders")

  products          Product[]
  customOrderQuotes CustomOrderQuote[]
  rentalItems       RentalItem[]

  conversationsAsUser1 Conversation[] @relation("ConversationsAsUser1")
  conversationsAsUser2 Conversation[] @relation("ConversationsAsUser2")
  sentMessages         Message[]      @relation("SentMessages")

  sellerPayouts SellerPayout[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([sellerStatus])
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  userId    Int
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Session {
  id        String   @id @default(uuid())
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?
  image       String?
  parentId    Int?
  order       Int     @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([slug])
  @@index([parentId])
}

enum ProductType {
  SALE
  RENTAL
  BOTH
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

model Product {
  id               Int           @id @default(autoincrement())
  sellerId         Int
  categoryId       Int
  name             String
  slug             String        @unique
  description      String?
  shortDescription String?
  price            Decimal       @db.Decimal(15, 2)
  comparePrice     Decimal?      @db.Decimal(15, 2)
  sku              String?       @unique
  type             ProductType   @default(SALE)
  status           ProductStatus @default(DRAFT)
  metaTitle        String?
  metaDescription  String?
  tags             String[]
  rating           Float         @default(0)
  reviewCount      Int           @default(0)
  viewCount        Int           @default(0)
  soldCount        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  publishedAt      DateTime?

  seller     User             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category   Category         @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  reviews    Review[]
  comments   Comment[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  rentalItem RentalItem?

  @@index([sellerId])
  @@index([categoryId])
  @@index([slug])
  @@index([status])
  @@index([type])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String
  alt       String?
  order     Int     @default(0)
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id         Int      @id @default(autoincrement())
  productId  Int
  name       String
  sku        String?  @unique
  price      Decimal? @db.Decimal(15, 2)
  stock      Int      @default(0)
  attributes Json
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([productId])
  @@index([sku])
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  variantId Int
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, variantId])
  @@index([userId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPING
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIAL
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  MOMO
  VNPAY
  ZALOPAY
  CREDIT_CARD
}

enum EscrowStatus {
  HOLDING
  RELEASED
  REFUNDED
}

model Order {
  id               Int           @id @default(autoincrement())
  userId           Int
  sellerId         Int
  orderNumber      String        @unique
  shippingName     String
  shippingPhone    String
  shippingAddress  String
  shippingCity     String
  shippingDistrict String
  shippingWard     String
  shippingNote     String?
  subtotal         Decimal       @db.Decimal(15, 2)
  shippingFee      Decimal       @default(0) @db.Decimal(15, 2)
  discount         Decimal       @default(0) @db.Decimal(15, 2)
  tax              Decimal       @default(0) @db.Decimal(15, 2)
  total            Decimal       @db.Decimal(15, 2)
  status           OrderStatus   @default(PENDING)
  paymentStatus    PaymentStatus @default(PENDING)
  paymentMethod    PaymentMethod
  escrowStatus     EscrowStatus  @default(HOLDING)
  payoutId         Int?
  customerNote     String?
  adminNote        String?
  trackingCode     String?
  shippingCarrier  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  confirmedAt      DateTime?
  shippedAt        DateTime?
  deliveredAt      DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?

  user           User                 @relation("CustomerOrders", fields: [userId], references: [id])
  seller         User                 @relation("SellerOrders", fields: [sellerId], references: [id])
  items          OrderItem[]
  payments       Payment[]
  statusHistory  OrderStatusHistory[]
  returnRequests ReturnRequest[]
  payout         SellerPayout?        @relation(fields: [payoutId], references: [id])

  @@index([userId])
  @@index([sellerId])
  @@index([orderNumber])
  @@index([status])
  @@index([escrowStatus])
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  productId   Int
  variantId   Int?
  productName String
  variantName String?
  price       Decimal  @db.Decimal(15, 2)
  quantity    Int
  subtotal    Decimal  @db.Decimal(15, 2)
  createdAt   DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  reviews Review[]

  @@index([orderId])
}

model OrderStatusHistory {
  id        Int         @id @default(autoincrement())
  orderId   Int
  status    OrderStatus
  note      String?
  createdBy Int?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  SHIPPING_BACK
  RECEIVED
  REFUNDED
  CLOSED
}

enum ReturnReason {
  WRONG_ITEM
  DAMAGED
  NOT_AS_DESCRIBED
  MISSING_PARTS
  OTHER
}

model ReturnRequest {
  id              Int          @id @default(autoincrement())
  orderId         Int
  userId          Int
  reason          ReturnReason
  description     String
  images          String[]
  videos          String[]
  status          ReturnStatus @default(PENDING)
  trackingCode    String?
  shippingCarrier String?      @default("GHTK")
  sellerNote      String?
  adminNote       String?
  refundAmount    Decimal?     @db.Decimal(15, 2)
  refundedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  resolvedAt      DateTime?

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

enum PaymentType {
  ORDER
  CUSTOM_DEPOSIT
  CUSTOM_FINAL
  RENTAL_DEPOSIT
  RENTAL_FEE
}

model Payment {
  id              Int           @id @default(autoincrement())
  orderId         Int?
  customOrderId   Int?
  rentalOrderId   Int?
  amount          Decimal       @db.Decimal(15, 2)
  paymentMethod   PaymentMethod
  paymentType     PaymentType
  status          PaymentStatus @default(PENDING)
  transactionId   String?       @unique
  transactionData Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order       Order?       @relation(fields: [orderId], references: [id])
  customOrder CustomOrder? @relation(fields: [customOrderId], references: [id])
  rentalOrder RentalOrder? @relation(fields: [rentalOrderId], references: [id])

  @@index([orderId])
  @@index([customOrderId])
  @@index([rentalOrderId])
  @@index([transactionId])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model SellerPayout {
  id              Int          @id @default(autoincrement())
  sellerId        Int
  amount          Decimal      @db.Decimal(15, 2)
  platformFee     Decimal      @db.Decimal(15, 2)
  netAmount       Decimal      @db.Decimal(15, 2)
  status          PayoutStatus @default(PENDING)
  bankName        String?
  bankAccount     String?
  bankAccountName String?
  transferNote    String?
  transferProof   String?
  processedBy     Int?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  seller User    @relation(fields: [sellerId], references: [id])
  orders Order[]

  @@index([sellerId])
  @@index([status])
}

model Review {
  id          Int      @id @default(autoincrement())
  userId      Int
  productId   Int
  orderItemId Int?
  rating      Int
  title       String?
  content     String
  images      String[]
  videos      String[]
  sellerReply String?
  repliedAt   DateTime?
  isVerified  Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([orderItemId])
  @@index([rating])
}

model Comment {
  id          Int      @id @default(autoincrement())
  userId      Int
  productId   Int
  parentId    Int?
  content     String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([userId])
  @@index([productId])
  @@index([parentId])
}

enum CustomOrderStatus {
  DRAFT
  SUBMITTED
  QUOTED
  QUOTE_ACCEPTED
  DEPOSIT_PAID
  IN_PROGRESS
  REVISION_REQUESTED
  READY
  COMPLETED
  CANCELLED
}

model Measurement {
  id                     Int      @id @default(autoincrement())
  userId                 Int
  name                   String
  height                 Float?
  weight                 Float?
  chest                  Float?
  waist                  Float?
  hips                   Float?
  shoulder               Float?
  armLength              Float?
  legLength              Float?
  neck                   Float?
  additionalMeasurements Json?
  notes                  String?
  isDefault              Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  customOrders CustomOrder[]

  @@index([userId])
}

model CustomOrder {
  id              Int               @id @default(autoincrement())
  userId          Int
  sellerId        Int
  measurementId   Int?
  orderNumber     String            @unique
  title           String
  description     String
  referenceImages String[]
  characterName   String?
  animeName       String?
  specialRequests String?
  deadline        DateTime?
  status          CustomOrderStatus @default(DRAFT)
  estimatedPrice  Decimal?          @db.Decimal(15, 2)
  depositAmount   Decimal?          @db.Decimal(15, 2)
  finalAmount     Decimal?          @db.Decimal(15, 2)
  totalPaid       Decimal           @default(0) @db.Decimal(15, 2)
  shippingFee     Decimal?          @db.Decimal(15, 2)
  trackingCode    String?
  shippingCarrier String?
  actualWeight    Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  submittedAt     DateTime?
  acceptedAt      DateTime?
  completedAt     DateTime?

  user            User                  @relation("CustomerCustomOrders", fields: [userId], references: [id])
  seller          User                  @relation("SellerCustomOrders", fields: [sellerId], references: [id])
  measurement     Measurement?          @relation(fields: [measurementId], references: [id])
  quotes          CustomOrderQuote[]
  progressUpdates CustomOrderProgress[]
  revisions       CustomOrderRevision[]
  payments        Payment[]

  @@index([userId])
  @@index([sellerId])
  @@index([orderNumber])
  @@index([status])
}

model CustomOrderQuote {
  id            Int      @id @default(autoincrement())
  customOrderId Int
  sellerId      Int
  quotedPrice   Decimal  @db.Decimal(15, 2)
  depositAmount Decimal  @db.Decimal(15, 2)
  estimatedDays Int
  description   String?
  isAccepted    Boolean  @default(false)
  isRejected    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customOrder CustomOrder @relation(fields: [customOrderId], references: [id], onDelete: Cascade)
  seller      User        @relation(fields: [sellerId], references: [id])

  @@index([customOrderId])
  @@index([sellerId])
}

model CustomOrderProgress {
  id              Int      @id @default(autoincrement())
  customOrderId   Int
  title           String
  description     String
  images          String[]
  videos          String[]
  progressPercent Int      @default(0)
  createdAt       DateTime @default(now())

  customOrder CustomOrder @relation(fields: [customOrderId], references: [id], onDelete: Cascade)

  @@index([customOrderId])
}

model CustomOrderRevision {
  id             Int       @id @default(autoincrement())
  customOrderId  Int
  description    String
  images         String[]
  videos         String[]
  sellerResponse String?
  respondedAt    DateTime?
  createdAt      DateTime  @default(now())

  customOrder CustomOrder @relation(fields: [customOrderId], references: [id], onDelete: Cascade)

  @@index([customOrderId])
}

enum RentalStatus {
  PENDING
  CONFIRMED
  DEPOSIT_PAID
  READY_FOR_PICKUP
  RENTED
  RETURNED
  DEPOSIT_REFUNDED
  COMPLETED
  CANCELLED
  OVERDUE
}

enum RentalItemCondition {
  EXCELLENT
  GOOD
  FAIR
  DAMAGED
}

model RentalItem {
  id            Int                 @id @default(autoincrement())
  productId     Int                 @unique
  sellerId      Int
  pricePerDay   Decimal             @db.Decimal(15, 2)
  depositAmount Decimal             @db.Decimal(15, 2)
  minDays       Int                 @default(1)
  maxDays       Int?
  condition     RentalItemCondition @default(EXCELLENT)
  isAvailable   Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller       User          @relation(fields: [sellerId], references: [id])
  rentalOrders RentalOrder[]

  @@index([sellerId])
  @@index([isAvailable])
}

model RentalOrder {
  id                Int                  @id @default(autoincrement())
  userId            Int
  rentalItemId      Int
  orderNumber       String               @unique
  startDate         DateTime
  endDate           DateTime
  actualReturnDate  DateTime?
  pricePerDay       Decimal              @db.Decimal(15, 2)
  totalDays         Int
  rentalFee         Decimal              @db.Decimal(15, 2)
  depositAmount     Decimal              @db.Decimal(15, 2)
  lateFee           Decimal              @default(0) @db.Decimal(15, 2)
  damageFee         Decimal              @default(0) @db.Decimal(15, 2)
  refundAmount      Decimal              @default(0) @db.Decimal(15, 2)
  status            RentalStatus         @default(PENDING)
  conditionAtPickup RentalItemCondition?
  pickupNotes       String?
  pickupImages      String[]
  pickupVideos      String[]
  conditionAtReturn RentalItemCondition?
  returnNotes       String?
  returnImages      String[]
  returnVideos      String[]
  damageDescription String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  confirmedAt       DateTime?
  pickedUpAt        DateTime?
  returnedAt        DateTime?
  completedAt       DateTime?

  user       User       @relation(fields: [userId], references: [id])
  rentalItem RentalItem @relation(fields: [rentalItemId], references: [id])
  payments   Payment[]

  @@index([userId])
  @@index([rentalItemId])
  @@index([orderNumber])
  @@index([status])
  @@index([startDate, endDate])
}

enum NotificationType {
  ORDER_STATUS
  PAYMENT
  CUSTOM_ORDER
  RENTAL
  REVIEW
  SYSTEM
  PROMOTION
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  content   String
  link      String?
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model SystemFee {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  feeType     String
  feeValue    Decimal  @db.Decimal(10, 4)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model Conversation {
  id            String    @id @default(uuid())
  user1Id       Int
  user2Id       Int
  orderId       Int?
  customOrderId Int?
  rentalOrderId Int?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user1    User      @relation("ConversationsAsUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("ConversationsAsUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([orderId])
  @@index([customOrderId])
  @@index([rentalOrderId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       Int
  content        String   @db.Text
  attachments    String[]
  isRead         Boolean  @default(false)
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}
